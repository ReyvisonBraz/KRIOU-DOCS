# ============================================================
# KRIOU DOCS — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local — ele contém segredos reais.
# ============================================================

# ----------------------------------------------------------
# SUPABASE
# Onde encontrar: supabase.com → seu projeto → Settings → API
# ----------------------------------------------------------

# URL do projeto (ex: https://abcdefghijkl.supabase.co)
VITE_SUPABASE_URL=

# Chave pública anon — segura para expor no client-side
# Use SEMPRE a "anon / public", NUNCA a "service_role"
VITE_SUPABASE_ANON_KEY=
